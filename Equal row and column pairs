from typing import List

class Solution:
    def equalPairs(self, grid: List[List[int]]) -> int:
        row_count = {}

        # Count each row
        for row in grid:
            t = tuple(row)
            row_count[t] = row_count.get(t, 0) + 1

        ans = 0

        # Compare each column with rows
        n = len(grid)
        for c in range(n):
            col = tuple(grid[r][c] for r in range(n))
            ans += row_count.get(col, 0)

        return ans
